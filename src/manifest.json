{
    "manifest_version": 3,
    "name": "Flotsam (auto-close tabs after specified time unless anchored)",
    "short_name": "Flotsam",
    "description": "Auto-close tabs after a set time unless explicitly anchored.",
    "homepage_url": "https://github.com/gniewomir/flotsam",
    "author": "Gniewomir Świechowski",
    "version": "0.4.7",
    "minimum_chrome_version": "102",
    "incognito": "not_allowed",
    "permissions": ["tabs", "alarms", "storage", "contextMenus"],
    "background": {
        "service_worker": "service-worker/background.js"
    },
    "icons": {
        "16": "icons/icon-floating-16.png",
        "24": "icons/icon-floating-24.png",
        "32": "icons/icon-floating-32.png",
        "48": "icons/icon-floating-48.png",
        "128": "icons/icon-floating-128.png"
    },
    "action": {
        "default_title": "Flotsam",
        "default_icon": {
            "16": "icons/icon-floating-16.png",
            "24": "icons/icon-floating-24.png",
            "32": "icons/icon-floating-32.png"
        }
    },
    "options_page": "options/options.html"
}
