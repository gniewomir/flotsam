{
  "name": "flotsam-extension",
  "version": "0.3.0",
  "private": true,
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc -p . --noEmit",
    "watch": "node scripts/watch.mjs",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.38",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
